{
  "name": "pi-sentry",
  "version": "0.1.11",
  "description": "Sentry AI Monitoring extension for pi coding agent sessions and tool calls",
  "type": "module",
  "main": "./pi-extension/index.ts",
  "pi": {
    "extensions": [
      "./pi-extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "pi-extension",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npx oxlint",
    "format": "npx oxfmt pi-extension/ skills/",
    "format:check": "npx oxfmt --check pi-extension/ skills/",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "prepare": "git config core.hooksPath .githooks",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "pi",
    "pi-package",
    "extension",
    "sentry",
    "observability",
    "ai-monitoring"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sentry/core": "^10.47.0",
    "@sentry/node-core": "^10.44.0",
    "strip-json-comments": "^5.0.1"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
